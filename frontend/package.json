{
  "name": "amiweave-desktop",
  "version": "0.3.0-rc.2",
  "description": "A self-hostable AI companion desktop application with long-term memory and proactive presence.",
  "author": "Amiweave contributors",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "node scripts/electron-dev.mjs",
    "icon:regenerate": "python scripts/regenerate-icon.py",
    "electron:build": "node scripts/electron-pack.mjs",
    "electron:build:win": "node scripts/electron-pack.mjs win",
    "electron:build:mac": "node scripts/electron-pack.mjs mac",
    "electron:release": "node scripts/electron-release.mjs",
    "electron:release:minor": "node scripts/electron-release.mjs minor",
    "electron:release:major": "node scripts/electron-release.mjs major",
    "preview": "vite preview",
    "test": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@stomp/stompjs": "^7.0.0",
    "axios": "^1.18.1",
    "bytenode": "^1.6.0",
    "dompurify": "^3.4.12",
    "element-plus": "^2.14.3",
    "gsap": "^3.15.0",
    "get-windows": "^9.3.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.39",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.11",
    "asarmor": "^3.0.2",
    "electron": "^42.3.2",
    "electron-builder": "^26.15.3",
    "javascript-obfuscator": "^5.4.7",
    "rcedit": "^4.0.1",
    "sass": "^1.101.0",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "form-data": "^4.0.6"
  },
  "build": {
    "appId": "com.amiweave.desktop",
    "productName": "Amiweave",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [],
    "asar": true,
    "asarUnpack": [],
    "afterPack": "scripts/after-pack.mjs",
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "electronFuses": {
      "runAsNode": false,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "onlyLoadAppFromAsar": true,
      "enableEmbeddedAsarIntegrityValidation": false,
      "grantFileProtocolExtraPrivileges": true
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.social-networking"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "guid": "8F3C2A1B-4D5E-6F70-8A9B-0C1D2E3F4A5B",
      "include": "build/installer.nsh",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Amiweave",
      "uninstallDisplayName": "Amiweave",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  }
}
